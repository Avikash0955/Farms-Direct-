<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | FarmDirect</title>
  <link rel="preconnect" href="https://images.unsplash.com">
  <link rel="stylesheet" href="/public/css/styles.css">
</head>
<body>
  <header class="site-header">
    <a class="brand" href="/">
      <span class="brand-mark">FD</span>
      <span>FarmDirect</span>
    </a>

    <button class="nav-toggle" type="button" data-nav-toggle aria-label="Open menu">Menu</button>

    <nav class="site-nav" data-nav>
      <a href="/">Home</a>
      <a href="/marketplace">Marketplace</a>
      <a href="/about">About</a>
      <% if (currentUser) { %>
        <a href="/dashboard">Dashboard</a>
        <a href="/orders">Orders</a>
        <a href="/profile">Profile</a>
        <% if (currentUser.role === 'farmer') { %>
          <a class="nav-action" href="/products/new">Add Product</a>
        <% } %>
        <form action="/auth/logout" method="POST" class="nav-form">
          <button type="submit">Logout</button>
        </form>
      <% } else { %>
        <a href="/login">Login</a>
        <a class="nav-action" href="/signup">Signup</a>
      <% } %>
    </nav>
  </header>

  <main>
    <%- include('flash') %>
