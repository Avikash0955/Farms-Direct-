<%- include('../partials/header') %>

<section class="auth-shell">
  <div class="auth-copy">
    <p class="eyebrow">Join FarmDirect</p>
    <h1>Create your account</h1>
    <p>Upload your profile picture, choose your role, and start using the marketplace.</p>
    <img
      src="https://images.unsplash.com/photo-1605000797499-95a51c5269ae?auto=format&fit=crop&w=900&q=80"
      alt="Farm harvest basket"
    >
  </div>

  <form class="form-panel" action="/auth/signup" method="POST" enctype="multipart/form-data" data-validate-passwords>
    <label>
      Full Name
      <input type="text" name="name" required placeholder="Enter your name">
    </label>

    <label>
      Email
      <input type="email" name="email" required placeholder="name@example.com">
    </label>

    <div class="two-column">
      <label>
        Password
        <input type="password" name="password" required minlength="6" placeholder="Minimum 6 characters">
      </label>
      <label>
        Confirm Password
        <input type="password" name="confirmPassword" required minlength="6" placeholder="Repeat password">
      </label>
    </div>

    <div class="two-column">
      <label>
        Account Type
        <select name="role" required>
          <option value="customer">Customer</option>
          <option value="farmer">Farmer</option>
        </select>
      </label>
      <label>
        Phone
        <input type="tel" name="phone" placeholder="Optional">
      </label>
    </div>

    <label>
      Address
      <textarea name="address" rows="3" placeholder="Village, city, state"></textarea>
    </label>

    <label>
      Profile Picture
      <input type="file" name="profilePic" accept="image/jpeg,image/png,image/webp">
    </label>

    <p class="form-error" data-form-error></p>

    <button class="btn btn-primary full-width" type="submit">Create Account</button>
    <p class="form-note">Already registered? <a href="/login">Login here</a>.</p>
  </form>
</section>

<%- include('../partials/footer') %>
