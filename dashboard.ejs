<%- include('../partials/header') %>

<section class="dashboard-hero">
  <div>
    <p class="eyebrow"><%= currentUser.role === 'farmer' ? 'Farmer Dashboard' : 'Customer Dashboard' %></p>
    <h1>Hello, <%= currentUser.name %></h1>
    <p>
      <% if (currentUser.role === 'farmer') { %>
        Manage your farm listings and customer orders.
      <% } else { %>
        Browse fresh products and track your orders.
      <% } %>
    </p>
  </div>
  <div class="profile-chip">
    <% if (currentUser.profilePic) { %>
      <img src="<%= currentUser.profilePic %>" alt="<%= currentUser.name %> profile picture">
    <% } else { %>
      <span><%= currentUser.name.charAt(0).toUpperCase() %></span>
    <% } %>
    <div>
      <strong><%= currentUser.name %></strong>
      <small><%= currentUser.role %></small>
    </div>
  </div>
</section>

<section class="stats-band">
  <article>
    <strong><%= marketplaceCount %></strong>
    <span>Marketplace products</span>
  </article>
  <article>
    <strong><%= myOrders.length %></strong>
    <span>Recent orders</span>
  </article>
  <article>
    <strong><%= currentUser.role === 'farmer' ? myProducts.length : 'Fresh' %></strong>
    <span><%= currentUser.role === 'farmer' ? 'Your listings' : 'Products nearby' %></span>
  </article>
</section>

<section class="section dashboard-grid">
  <% if (currentUser.role === 'farmer') { %>
    <div>
      <div class="section-heading row-heading">
        <div>
          <p class="eyebrow">Listings</p>
          <h2>Your products</h2>
        </div>
        <a class="btn btn-primary" href="/products/new">Add Product</a>
      </div>

      <% if (myProducts.length) { %>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Name</th>
                <th>Category</th>
                <th>Qty</th>
                <th>Price</th>
                <th>Status</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% myProducts.forEach((product) => { %>
                <tr>
                  <td><%= product.name %></td>
                  <td><%= product.category %></td>
                  <td><%= product.quantity %> <%= product.unit %></td>
                  <td>Rs. <%= product.price %></td>
                  <td><%= product.isAvailable ? 'Available' : 'Hidden' %></td>
                  <td class="table-actions">
                    <form action="/products/<%= product._id %>/toggle" method="POST">
                      <button type="submit"><%= product.isAvailable ? 'Hide' : 'Show' %></button>
                    </form>
                    <form action="/products/<%= product._id %>?_method=DELETE" method="POST" data-confirm="Delete this product?">
                      <button type="submit">Delete</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <p class="empty-state">No products yet. Add your first crop listing.</p>
      <% } %>
    </div>
  <% } else { %>
    <div class="action-panel">
      <p class="eyebrow">Marketplace</p>
      <h2>Find seasonal crops</h2>
      <p>Browse fresh vegetables, fruits, grains, and organic products directly from farmers.</p>
      <a class="btn btn-primary" href="/marketplace">Start Shopping</a>
    </div>
  <% } %>

  <div>
    <div class="section-heading">
      <p class="eyebrow">Orders</p>
      <h2>Recent activity</h2>
    </div>
    <% if (myOrders.length) { %>
      <div class="order-list">
        <% myOrders.forEach((order) => { %>
          <article class="order-item">
            <strong><%= order.product ? order.product.name : 'Product' %></strong>
            <span><%= order.quantity %> <%= order.product ? order.product.unit : '' %> - Rs. <%= order.totalAmount %></span>
            <small>Status: <%= order.status %></small>
          </article>
        <% }) %>
      </div>
      <a class="text-link" href="/orders">View all orders</a>
    <% } else { %>
      <p class="empty-state">No orders yet.</p>
    <% } %>
  </div>
</section>

<%- include('../partials/footer') %>
